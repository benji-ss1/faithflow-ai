# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/faithflow

# Auth.js
AUTH_SECRET=change-me-run-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# S3 (or S3-compatible: MinIO, R2, Supabase Storage S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=faithflow-media
S3_ENDPOINT=

# Public app URL (used in outbound emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Streaming STT
DEEPGRAM_API_KEY=
NEXT_PUBLIC_AUDIO_WS_URL=ws://localhost:3001

# Summarization LLM (xAI, OpenAI-compatible)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-2-latest

# Email delivery (Phase 5)
# Leave RESEND_API_KEY unset in dev — verification / reset links will print
# to the terminal instead of being sent.
RESEND_API_KEY=
EMAIL_FROM=FaithFlow AI <no-reply@faithflow.ai>

# Stripe (Phase 5, test mode ONLY)
# Must be an sk_test_ key. The client refuses live keys until billing is
# explicitly enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
