{
  "name": "presentflow",
  "version": "0.1.6",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "electron:dev": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && npm run electron:build:tsc && cross-env NODE_ENV=development electron .\"",
    "electron:build:tsc": "tsc -p electron/tsconfig.json",
    "electron:build": "next build && npm run electron:build:tsc && electron-builder --mac dmg",
    "electron:build:tester": "bash scripts/build-tester.sh",
    "electron:build:win": "next build && npm run electron:build:tsc && electron-builder --win nsis",
    "electron:preview": "next build && npm run electron:build:tsc && cross-env NODE_ENV=production electron .",
    "ws": "tsx --env-file=.env.local scripts/audio-server.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "db:seed:bible": "tsx --env-file=.env.local scripts/seed-bible.ts",
    "db:seed:hymns": "tsx --env-file=.env.local scripts/seed-hymns.ts",
    "db:embed:bible": "tsx --env-file=.env.local scripts/embed-bible.ts",
    "db:embed:sermons": "tsx --env-file=.env.local scripts/embed-sermons.ts",
    "cron:prune-transcripts": "tsx --env-file=.env.local scripts/prune-transcripts.ts",
    "db:reset": "tsx scripts/reset.ts",
    "typecheck": "tsc --noEmit",
    "test:pair-code": "tsx --env-file=.env.local test/adversarial/pair-code.test.ts",
    "release": "./scripts/release.sh",
    "release:tag": "bash -c 'V=${npm_config_version:?Usage: npm run release:tag --version=vX.Y.Z}; npm version \"${V#v}\" --no-git-tag-version && git add package.json package-lock.json && git commit -m \"chore(release): $V\" && git tag \"$V\" && git push && git push --tags && echo \"✓ Pushed $V — GitHub Actions will build + publish the desktop release.\"'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@deepgram/sdk": "^5.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@napi-rs/canvas": "^0.1.60",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@supabase/supabase-js": "^2.110.2",
    "@types/adm-zip": "^0.5.8",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.18",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.4",
    "electron-updater": "^6.8.9",
    "fast-xml-parser": "^5.9.3",
    "isomorphic-dompurify": "^2.19.0",
    "libreoffice-convert": "^1.6.0",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.25",
    "otplib": "^12.0.1",
    "pdfjs-dist": "^4.9.155",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "sonner": "^1.7.1",
    "stripe": "^22.3.0",
    "tailwind-merge": "^2.5.5",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.30.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.0.0-beta.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.presentflow.app",
    "productName": "Present Flow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "config/**",
      "package.json",
      "!node_modules/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/@types/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/sax/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/argparse/**/*",
      "node_modules/semver/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/universalify/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "identity": null
    },
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "benji-ss1",
        "repo": "faithflow-ai",
        "vPrefixedTagName": true,
        "releaseType": "release"
      }
    ]
  }
}
